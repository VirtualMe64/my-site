---
import Section from './Section.astro'
import { getSection, contact } from '../content/site.js'
---

<Section {...getSection('contact')}>
  <ul class="links">
    {contact.map((link) => (
      <li class="row">
        <span class="label">{link.label}</span>
        <a href={link.href} target={link.external ? '_blank' : undefined} rel={link.external ? 'noreferrer' : undefined}>
          {link.display}
        </a>
      </li>
    ))}
  </ul>
</Section>

<style>
  .links {
    list-style: none;
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .row {
    display: flex;
    align-items: baseline;
    gap: 0.75em;
  }

  .label {
    flex: 0 0 6rem;
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-text-muted);
  }

  .row a {
    font-size: var(--text-base);
  }

  @media (max-width: 640px) {
    .label {
      flex-basis: 4.5rem;
    }
  }
</style>
