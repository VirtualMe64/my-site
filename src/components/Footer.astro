---
import TileWord from './TileWord.astro'
import { words, scrabbleScore } from '../content/scrabble.js'

// The static HTML gets a deterministic fallback word (and the build-time
// year); the client script below swaps in the values for the visitor's date,
// rebuilding the tiles with the same global .tile/.tileWord classes.
const fallback = words[0]
const year = new Date().getFullYear()
---

<footer class="footer">
  <div class="line">
    <p class="label">Scrabble word of the day:</p>
    <p class="row">
      <span class="word" data-word role="img" aria-label={fallback.text}><TileWord word={fallback.text} /></span>
      <span class="score" data-score>({scrabbleScore(fallback.text)})</span>
      <span class="def" data-def>{fallback.def}</span>
    </p>
    <p class="copy">&copy; <span data-year>{year}</span> Sammy Taubman</p>
  </div>
</footer>

<script>
  import { wordOfTheDay, scrabbleScore, LETTER_SCORES } from '../content/scrabble.js'

  const TILTS = [-2, 1.6, -1.1, 2.1, -1.7, 1.2, -2.2, 0.9, 1.9, -0.8, 1.4, -1.3]
  const word = wordOfTheDay()

  const wordEl = document.querySelector('[data-word]')
  wordEl.setAttribute('aria-label', word.text)
  wordEl.innerHTML = `<span class="tileWord" aria-hidden="true">${[...word.text]
    .map((l, i) => `<span class="tile" style="--tilt:${TILTS[i % TILTS.length]}deg">${l}<span class="value">${LETTER_SCORES[l] ?? 0}</span></span>`)
    .join('')}</span>`

  document.querySelector('[data-score]').textContent = `(${scrabbleScore(word.text)})`
  document.querySelector('[data-def]').textContent = word.def
  document.querySelector('[data-year]').textContent = String(new Date().getFullYear())
</script>

<style>
  .footer {
    border-top: 1px solid var(--color-rule);
    padding: var(--page-padding);
    min-height: 10rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .line {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }

  .row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.5em;
  }

  .label {
    font-size: var(--text-base);
    color: var(--color-text-muted);
  }

  .word {
    --tile: 1.5rem;
  }

  .score {
    font-size: var(--text-base);
    font-weight: 400;
    color: var(--color-text-muted);
  }

  .def {
    font-size: var(--text-base);
    font-style: italic;
    color: var(--color-text-muted);
  }

  .copy {
    margin-top: 0.5rem;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
</style>
