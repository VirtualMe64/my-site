---
import Section from './Section.astro'
import { getSection } from '../content/site.js'
import { roles } from '../content/roles.js'
import { md } from '../lib/md.js'
---

<Section {...getSection('experience')}>
  <ol class="roles">
    {roles.map((role) => (
      <li>
        <p class="company"><a href={role.url} target="_blank" rel="noreferrer">{role.company}</a></p>
        <p class="meta">{role.title}<span aria-hidden="true"> · </span>{role.dates}</p>
        <p class="roleDesc" set:html={md(role.description)} />
      </li>
    ))}
  </ol>
</Section>

<style>
  .roles {
    list-style: none;
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .company {
    font-size: var(--text-lg);
    font-weight: 700;
  }

  .meta {
    font-size: var(--text-base);
    font-style: italic;
    color: var(--color-text-muted);
  }

  .roleDesc {
    font-size: var(--text-base);
  }

  /* description links are underlined at rest; hover styling is global.
     :global because the markup comes from set:html */
  .roleDesc :global(a) {
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 3px;
  }
</style>
