---
import Headword from './Headword.astro'
import { projects } from '../content/projects.js'
import { md } from '../lib/md.js'

const rows = []
for (let i = 0; i < projects.length; i += 2) rows.push(projects.slice(i, i + 2))
---

<section id="projects">
  <div class="projects">
    <Headword pos="n. pl.">
      proj<span aria-hidden="true">·</span>ects
    </Headword>
    <p class="gloss">things i've made.</p>
    <div class="grid">
      {rows.map((row) => (
        <div class="row">
          {row.map((project) => (
            <article class="card">
              <div class="cardHead">
                <span class="name">{project.name} <span class="pos">{project.pos}</span></span>
              </div>
              <p class="def" set:html={md(project.def)} />
              <footer class="cardFoot">
                <span class="stack">{project.stack}</span>
                <span class="seeAlso">
                  See also:{' '}
                  {project.links.map((link, i) => (
                    <span><a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>{i < project.links.length - 1 && ', '}</span>
                  ))}
                </span>
              </footer>
            </article>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .projects {
    max-width: 60rem;
  }

  .gloss {
    margin-top: 1rem;
    font-weight: 300;
  }

  .grid {
    margin-top: 1rem;
    position: relative;
    border-bottom: 1px solid var(--color-rule);
  }

  /* center vertical — spans full grid height regardless of row count */
  .grid::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    transform: translateX(-0.5px);
    width: 1px;
    background: var(--color-rule);
    pointer-events: none;
  }

  .row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    border-top: 1px solid var(--color-rule);
  }

  .card {
    padding: 1.5rem 2rem 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card:nth-child(2) {
    padding-left: 2rem;
    padding-right: 0;
  }

  .cardHead {
    display: block;
  }

  .name {
    font-size: var(--text-md);
    font-weight: 700;
  }

  .pos {
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-text-muted);
  }

  .def {
    font-weight: 300;
    font-size: var(--text-base);
    line-height: 1.5;
    flex: 1;
  }

  /* link markup comes from set:html, so it needs :global */
  .def :global(a) {
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  .def :global(a:hover) {
    color: var(--color-accent);
  }

  .cardFoot {
    display: flex;
    align-items: baseline;
    margin-top: 0.25rem;
  }

  .stack {
    width: 50%;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: italic;
  }

  .seeAlso {
    width: 50%;
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-text-muted);
    text-align: right;
  }

  .seeAlso a {
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .seeAlso a:hover {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 3px;
  }

  @media (max-width: 640px) {
    .grid::before {
      display: none;
    }

    .row {
      grid-template-columns: 1fr;
    }

    .card {
      padding-right: 0;
    }

    .card:nth-child(2) {
      padding-left: 0;
      border-top: 1px solid var(--color-rule);
    }
  }
</style>
