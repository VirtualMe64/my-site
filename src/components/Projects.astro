---
import Section from './Section.astro'
import { getSection } from '../content/site.js'
import { projects } from '../content/projects.js'
import { md } from '../lib/md.js'

const rows = []
for (let i = 0; i < projects.length; i += 2) rows.push(projects.slice(i, i + 2))
---

<Section {...getSection('projects')}>
  <div class="grid">
    {rows.map((row) => (
      <div class="row">
        {row.map((project) => (
          <article class="card">
            <p class="name">{project.name}</p>
            <p class="def" set:html={md(project.def)} />
            <footer class="cardFoot">
              <span class="stack">{project.stack}</span>
              <span class="seeAlso">
                see:{' '}
                {project.links.map((link, i) => (
                  <span><a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>{i < project.links.length - 1 && ', '}</span>
                ))}
              </span>
            </footer>
          </article>
        ))}
      </div>
    ))}
  </div>
</Section>

<style>
  .grid {
    /* the grid (and its rules) extends 1rem past the text column on both
       sides, so the hover wash ends where the rules do and the card text
       stays aligned with the headword */
    margin: 1rem -1rem 0;
    position: relative;
    border-bottom: 1px solid var(--color-rule);
  }

  /* center vertical — spans full grid height regardless of row count */
  .grid::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    transform: translateX(-0.5px);
    width: 1px;
    background: var(--color-rule);
    pointer-events: none;
  }

  .row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    border-top: 1px solid var(--color-rule);
  }

  .card {
    padding: 1.5rem 2rem 1.5rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* hovering a card highlights its entry, like running a finger down the page */
  @media (hover: hover) {
    .card {
      transition: background-color 0.2s ease;
    }

    .name {
      transition: color 0.2s ease;
    }

    .card:hover {
      background-color: var(--color-wash);
    }

    .card:hover .name {
      color: var(--color-accent);
    }
  }

  .card:nth-child(2) {
    padding-left: 2rem;
    padding-right: 1rem;
  }

  .name {
    font-size: var(--text-md);
    font-weight: 700;
  }

  .pos {
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-text-muted);
  }

  .def {
    font-weight: 300;
    font-size: var(--text-base);
    line-height: 1.5;
    flex: 1;
  }

  /* definition links are underlined at rest; hover styling is global.
     :global because the markup comes from set:html */
  .def :global(a) {
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 3px;
  }

  .cardFoot {
    display: flex;
    align-items: baseline;
    margin-top: 0.25rem;
  }

  .stack {
    width: 50%;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: italic;
  }

  .seeAlso {
    width: 50%;
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-text-muted);
    text-align: right;
  }

  /* underlined at rest so it reads as a link; hover bolds instead */
  .seeAlso a {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 3px;
  }

  .seeAlso a:hover {
    font-weight: 700;
  }

  @media (max-width: 640px) {
    .grid::before {
      display: none;
    }

    .row {
      grid-template-columns: 1fr;
    }

    .grid {
      margin-left: 0;
      margin-right: 0;
    }

    .card {
      padding-right: 0;
      padding-left: 0;
    }

    .card:nth-child(2) {
      padding-left: 0;
      border-top: 1px solid var(--color-rule);
    }
  }
</style>
