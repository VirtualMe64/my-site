---
// A section is a played word: the label spelled in tiles, its real Scrabble
// score jotted beside it, then the gloss and the section body. The h2 stays
// screen-reader-friendly via aria-label; the tiles are decoration.
import TileWord from './TileWord.astro'
import { scrabbleScore } from '../content/scrabble.js'

const { id, label, gloss } = Astro.props
const played = label.toUpperCase()
---

<section id={id}>
  <div class="inner">
    <h2 class="play" aria-label={label}>
      <TileWord word={played} spin={played.length} />
      <span class="score" aria-hidden="true">— {scrabbleScore(played)}</span>
    </h2>
    <p class="gloss">{gloss}</p>
    <slot />
  </div>
</section>

<style>
  .inner {
    max-width: 60rem;
  }

  .play {
    --tile: clamp(1.6rem, 3.2vw, 2.5rem);
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  .score {
    font-size: var(--text-md);
    font-style: italic;
    font-weight: 400;
    color: var(--color-text-muted);
  }

  .gloss {
    margin-top: 1rem;
    font-weight: 300;
    font-style: italic;
    color: var(--color-text-muted);
  }
</style>
