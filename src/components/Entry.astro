---
import Headword from './Headword.astro'
import { hero } from '../content/site.js'
---

<section id="home">
  <div class="entry">
    <Headword as="h1" pos={hero.pos}>
      Sam<span aria-hidden="true">·</span>my Taub<span aria-hidden="true">·</span>man
    </Headword>

    <p class="definitions">
      {hero.definitions.map((def, i) => (
        <><span class="num">{i + 1}.</span> {def}{' '}</>
      ))}
    </p>
  </div>
</section>

<style>
  .entry {
    max-width: 60rem;
    --headword-size: var(--headword-size-hero);
    --headword-color: var(--color-accent);
  }

  .definitions {
    max-width: 40rem;
    margin-top: 1rem;
    font-weight: 300;
  }

  .num {
    font-weight: 700;
    color: var(--color-accent);
  }
</style>
