---
import { hero } from '../content/site.js'
---

<section id="home">
  <div class="entry">
    <!-- the interpunct spans must stay aria-hidden so screen readers hear
         "Sammy Taubman", not the syllable breaks -->
    <h1 class="headword">
      Sam<span aria-hidden="true">·</span>my Taub<span aria-hidden="true">·</span>man
      <span class="pos">{hero.pos}</span>
    </h1>

    <p class="definitions">
      {hero.definitions.map((def, i) => (
        <><span class="num">{i + 1}.</span> {def}{' '}</>
      ))}
    </p>
  </div>
</section>

<style>
  .entry {
    max-width: 60rem;
    --headword-size: var(--headword-size-hero);
  }

  .definitions {
    max-width: 40rem;
    margin-top: 1rem;
    font-weight: 300;
  }

  .num {
    font-weight: 700;
    color: var(--color-accent);
  }
</style>
