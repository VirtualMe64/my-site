---
// The nav derives from the same sections list that drives the section
// headers, so the two can't fall out of sync.
import { sections } from '../content/site.js'
---

<nav class="sidebar" aria-label="Primary">
  <a class="logo" href="#home" aria-label="Home">
    <img src="/favicon.svg" alt="" width="28" height="28" />
  </a>
  <ul class="list">
    {sections.map((link, i) => (
      <li class:list={{ home: link.id === 'home' }}>
        <a
          href={`#${link.id}`}
          class:list={['link', { active: i === 0 }]}
          aria-current={i === 0 ? 'true' : undefined}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<script>
  // Scroll-spy: highlight the link whose section crosses a thin band across
  // the middle of the viewport. Scoped to .list so the logo link stays out.
  const links = [...document.querySelectorAll('nav[aria-label="Primary"] .list a[href^="#"]')]

  function setActive(id) {
    for (const link of links) {
      const active = link.getAttribute('href') === `#${id}`
      link.classList.toggle('active', active)
      if (active) link.setAttribute('aria-current', 'true')
      else link.removeAttribute('aria-current')
    }
  }

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) setActive(entry.target.id)
      }
    },
    { rootMargin: '-50% 0px -50% 0px', threshold: 0 },
  )

  for (const link of links) {
    const section = document.querySelector(link.getAttribute('href'))
    if (section) observer.observe(section)
  }
</script>

<style>
  .sidebar {
    align-self: stretch;          /* full page height so the list can travel */
    flex: 0 0 12rem;
    position: relative;
    padding: var(--page-padding);
  }

  /* desktop: the logo mark sits in the page's top-left corner */
  .logo {
    position: absolute;
    top: var(--page-padding);
    left: var(--page-padding);
    display: block;
    transition: transform 0.2s ease;
  }

  .logo img {
    display: block;
  }

  .logo:hover,
  .logo:focus-visible {
    transform: scale(1.08);
  }

  @media (prefers-reduced-motion: reduce) {
    .logo:hover,
    .logo:focus-visible {
      transform: none;
    }
  }

  /* the vertical divider — inset from the top, flush with the bottom */
  .sidebar::after {
    content: '';
    position: absolute;
    top: 4rem;
    bottom: 0;
    right: 0;
    width: 1px;
    background: var(--color-rule);
  }

  .list {
    position: sticky;
    top: 4rem;
    margin-top: calc(50dvh - 8rem); /* start roughly centered in the hero */
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .link {
    display: inline-block;
    font-size: var(--text-md);
    color: var(--color-text);
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .link:hover,
  .link:focus-visible {
    color: var(--color-accent);
  }

  /* the section currently in view */
  .link.active {
    color: var(--color-accent);
    font-weight: 700;
    transform: translateX(4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .link {
      transition: color 0.2s ease;
    }
    .link.active {
      transform: none;
    }
  }

  @media (max-width: 640px) {
    .sidebar {
      flex: none;
      width: 100%;
      align-self: auto;
      position: static;
      padding: 1rem var(--page-padding) .75rem;
      border-bottom: 1px solid var(--color-rule);
      display: flex;
      align-items: center;
      justify-content: space-between;   /* logo left, links right */
    }

    .sidebar::after {
      display: none;
    }

    /* mobile: the tile IS the Home link — the text link hides to save width */
    .logo {
      position: static;
    }

    .logo img {
      width: 20px;
      height: 20px;
    }

    .list .home {
      display: none;
    }

    .list {
      position: static;
      flex-direction: row;
      margin-top: 0;
      gap: 1.5rem;
    }

    .link,
    .link.active {
      font-weight: 700;
      transform: none;
    }
  }
</style>
