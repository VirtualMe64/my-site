---
// The nav derives from the same sections list that drives the section
// headers, so the two can't fall out of sync.
import { sections } from '../content/site.js'
---

<nav class="sidebar" aria-label="Primary">
  <div class="rail">
    <!-- the brand is the two-tile rack alone — the wordmark's job is done
         by the hero's cross now. inlined (not the favicon <img>) so the
         viewBox crops to the tiles and the rects follow the hover color -->
    <a href="#home" class="brand" aria-label="Home">
      <svg class="mark" viewBox="0 7.5 32 17.5" aria-hidden="true">
        <g transform="rotate(-5 8.25 15.75)">
          <rect x="1" y="8.5" width="14.5" height="14.5" rx="2.5" fill="currentColor"/>
          <text x="7.9" y="15.4" dominant-baseline="central" text-anchor="middle" font-family="Georgia, 'Times New Roman', serif" font-size="11" font-weight="700" fill="#162013">S</text>
          <text x="14.1" y="21.6" text-anchor="end" font-family="Georgia, 'Times New Roman', serif" font-size="4.5" font-weight="700" fill="#162013">1</text>
        </g>
        <g transform="rotate(4 23.75 16.75)">
          <rect x="16.5" y="9.5" width="14.5" height="14.5" rx="2.5" fill="currentColor"/>
          <text x="23.4" y="16.4" dominant-baseline="central" text-anchor="middle" font-family="Georgia, 'Times New Roman', serif" font-size="11" font-weight="700" fill="#162013">T</text>
          <text x="29.6" y="22.6" text-anchor="end" font-family="Georgia, 'Times New Roman', serif" font-size="4.5" font-weight="700" fill="#162013">1</text>
        </g>
      </svg>
    </a>
    <ul class="list">
      {sections.map((link, i) => (
        <li class:list={{ home: link.id === 'home' }}>
          <a
            href={`#${link.id}`}
            class:list={['link', { active: i === 0 }]}
            aria-current={i === 0 ? 'true' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  // Scroll-spy: highlight the link whose section crosses a thin band across
  // the middle of the viewport. Scoped to .list so the brand link stays out.
  const links = [...document.querySelectorAll('nav[aria-label="Primary"] .list a[href^="#"]')]

  function setActive(id) {
    for (const link of links) {
      const active = link.getAttribute('href') === `#${id}`
      link.classList.toggle('active', active)
      if (active) link.setAttribute('aria-current', 'true')
      else link.removeAttribute('aria-current')
    }
  }

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) setActive(entry.target.id)
      }
    },
    { rootMargin: '-50% 0px -50% 0px', threshold: 0 },
  )

  for (const link of links) {
    const section = document.querySelector(link.getAttribute('href'))
    if (section) observer.observe(section)
  }
</script>

<style>
  .sidebar {
    align-self: stretch;          /* full page height so the divider spans it */
    flex: 0 0 14rem;
    position: relative;
    padding: var(--page-padding);
  }

  /* the vertical divider — all the way to the top */
  .sidebar::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    right: 0;
    width: 1px;
    background: var(--color-rule);
  }

  /* mark + nav anchored top-left; sticky only pins them there while the page
     scrolls — no drifting start position */
  .rail {
    position: sticky;
    top: 3rem;
  }

  /* gold at rest; hovering shifts the tiles (their rects fill with
     currentColor) to sage */
  .brand {
    display: inline-block;
    margin-bottom: 1.25rem;
    color: var(--color-accent);
    transition: color 0.2s ease;
  }

  .brand:hover,
  .brand:focus-visible {
    color: var(--color-text);
  }

  .mark {
    display: block;
    width: 5rem;
    height: auto;
  }

  .list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .link {
    display: inline-block;
    font-size: var(--text-md);
    font-weight: 300;          /* light, so the mark above carries the weight */
    color: var(--color-text);
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .link:hover,
  .link:focus-visible {
    color: var(--color-accent);
  }

  /* the section currently in view: gold + bold + shifted, like the tile
     words it points at */
  .link.active {
    font-weight: 700;
    color: var(--color-accent);
    transform: translateX(4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .link {
      transition: color 0.2s ease;
    }
    .link.active {
      transform: none;
    }
  }

  @media (max-width: 640px) {
    .sidebar {
      flex: none;
      width: 100%;
      align-self: auto;
      position: static;
      padding: .875rem var(--page-padding);
      border-bottom: 1px solid var(--color-rule);
    }

    .sidebar::after {
      display: none;
    }

    .rail {
      position: static;
      display: flex;
      align-items: center;
      justify-content: space-between;   /* rack left, links right */
    }

    /* mobile: the rack shrinks into the bar — sized so the tiles optically
       match the nav links' cap height; nudged up because text's visual
       center sits above its geometric center */
    .brand {
      margin-bottom: 0;
    }

    .mark {
      width: 3rem;
      transform: translateY(-2px);
    }

    .list .home {
      display: none;
    }

    .list {
      flex-direction: row;
      gap: 1.5rem;
    }

    /* regular weight at rest so bold means "you are here"; no x-shift in
       the horizontal bar */
    .link {
      font-weight: 400;
    }

    .link.active {
      transform: none;
    }
  }
</style>
