---
// The nav derives from the same sections list that drives the section
// headers, so the two can't fall out of sync.
import { sections } from '../content/site.js'
---

<nav class="sidebar" aria-label="Primary">
  <div class="rail">
    <!-- desktop anchor: a guide-word mark — the name styled like a small
         headword. the mobile bar keeps the tile instead (media query below) -->
    <a href="#home" class="name">Sam<span aria-hidden="true">·</span>my</a>
    <a class="logo" href="#home" aria-label="Home">
      <img src="/favicon.svg" alt="" width="20" height="20" />
    </a>
    <ul class="list">
      {sections.map((link, i) => (
        <li class:list={{ home: link.id === 'home' }}>
          <a
            href={`#${link.id}`}
            class:list={['link', { active: i === 0 }]}
            aria-current={i === 0 ? 'true' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  // Scroll-spy: highlight the link whose section crosses a thin band across
  // the middle of the viewport. Scoped to .list so the logo link stays out.
  const links = [...document.querySelectorAll('nav[aria-label="Primary"] .list a[href^="#"]')]

  function setActive(id) {
    for (const link of links) {
      const active = link.getAttribute('href') === `#${id}`
      link.classList.toggle('active', active)
      if (active) link.setAttribute('aria-current', 'true')
      else link.removeAttribute('aria-current')
    }
  }

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) setActive(entry.target.id)
      }
    },
    { rootMargin: '-50% 0px -50% 0px', threshold: 0 },
  )

  for (const link of links) {
    const section = document.querySelector(link.getAttribute('href'))
    if (section) observer.observe(section)
  }
</script>

<style>
  .sidebar {
    align-self: stretch;          /* full page height so the divider spans it */
    flex: 0 0 14rem;
    position: relative;
    padding: var(--page-padding);
  }

  /* the vertical divider — all the way to the top */
  .sidebar::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    right: 0;
    width: 1px;
    background: var(--color-rule);
  }

  /* mark + nav anchored top-left; sticky only pins them there while the page
     scrolls — no drifting start position */
  .rail {
    position: sticky;
    top: 3rem;
  }

  .name {
    display: inline-block;
    margin-bottom: 1.25rem;
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: 0.01em;   /* match the headwords */
    color: var(--color-accent);
    transition: color 0.2s ease;
  }

  .name:hover,
  .name:focus-visible {
    color: var(--color-text);
  }

  /* the tile is mobile-only */
  .logo {
    display: none;
  }

  .logo img {
    display: block;
    width: 20px;
    height: 20px;
  }

  .list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .link {
    display: inline-block;
    font-size: var(--text-md);
    font-weight: 300;          /* light, so the mark above carries the weight */
    color: var(--color-text);
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .link:hover,
  .link:focus-visible {
    color: var(--color-accent);
  }

  /* the section currently in view: bold + shifted — gold stays the mark's */
  .link.active {
    font-weight: 700;
    transform: translateX(4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .link {
      transition: color 0.2s ease;
    }
    .link.active {
      transform: none;
    }
  }

  @media (max-width: 640px) {
    .sidebar {
      flex: none;
      width: 100%;
      align-self: auto;
      position: static;
      padding: .875rem var(--page-padding);
      border-bottom: 1px solid var(--color-rule);
    }

    .sidebar::after {
      display: none;
    }

    .rail {
      position: static;
      display: flex;
      align-items: center;
      justify-content: space-between;   /* logo left, links right */
    }

    /* mobile: the name is desktop-only; the tile IS the Home link — the
       text link hides to save width */
    .name {
      display: none;
    }

    .logo {
      display: block;
    }

    .list .home {
      display: none;
    }

    .list {
      flex-direction: row;
      gap: 1.5rem;
    }

    /* regular weight at rest so bold means "you are here" (the base
       .link.active rule already bolds the active link); no x-shift in the
       horizontal bar */
    .link {
      font-weight: 400;
    }

    .link.active {
      transform: none;
    }
  }
</style>
